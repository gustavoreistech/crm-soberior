# ============================================
# SOBERIOR OS - Configuração de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha
# ============================================

# --- Banco de Dados (OBRIGATÓRIO) ---
# URL de conexão PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/soberior_os

# --- Autenticação (OBRIGATÓRIO) ---
# Gere um token seguro com: openssl rand -base64 32
NEXTAUTH_SECRET=seu-secret-aqui
NEXTAUTH_URL=http://localhost:3000

# --- Configurações via UI ---
# As credenciais abaixo (DeepSeek, Evolution, Asaas, n8n)
# são configuradas pela página /settings do sistema
# e persistidas no banco PostgreSQL (tabela SystemConfig).

# Opcional: defina variáveis direto no .env como fallback
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# EVOLUTION_API_URL=https://...
# EVOLUTION_API_KEY=...
# ASAAS_API_KEY=...
# N8N_WEBHOOK_SECRET=...
