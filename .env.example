# ============================================
# SOBERIOR OS - Configuração de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha
# ============================================

# --- Google Sheets (OBRIGATÓRIO) ---
# Credenciais da Service Account do Google Cloud
# Necessário para bootstrap do banco de dados
GOOGLE_CLIENT_EMAIL=seu-servico@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=1abc123...sheet-id

# --- Configurações via UI ---
# As demais credenciais (DeepSeek, Evolution, Asaas, n8n)
# são configuradas pela página /settings do sistema
# e persistidas na aba "Configuracoes" do Google Sheets.
